{
  "version": 3,
  "framework": {
    "name": "nitro",
    "version": "3.0.260603-beta"
  },
  "overrides": {
    "index.html": {
      "path": ""
    }
  },
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/assets/(.*)"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/api/(?:.*))",
      "dest": "/api/[...]-isr?__isr_route=$__isr_route"
    },
    {
      "src": "/(.*)",
      "dest": "/__server"
    }
  ]
}